@article{SAAD2026102076,
 abstract = {Emergent trees play a disproportionate role in tropical forest function, contributing substantially to aboveground biomass and biodiversity. However, the low density, long lifespans, and uneven distributions of emergent tree species across landscapes have limited our understanding of their sensitivity to anthropogenic disturbances. Here, we developed and tested a framework using multiple remote sensing sources to monitor target crowns of the emergent Dipteryx panamensis across northern Costa Rica and southern Nicaragua. In this analysis, we evaluated four sensor configurations combining open-access optical and radar datasets. In contrast to earlier limited-area studies, spectral-only models performed poorly. Models combining spectral and SAR datasets achieved higher accuracies, demonstrating the complementarity of datasets for consistent emergent crown detection at landscape scales. Our all-data model generated a highly accurate crown-level distribution map for D. panamensis (F1 score = 0.94). We found that emergent crowns persisted in both intact forests and pastures, raising questions about the long-term survival of these populations under continuing disturbances. Across Costa Rica and Nicaragua, we observed higher densities within forest environments, with sharp declines toward the edges and non-forest areas, indicating that persistence is spatially structured by forest integrity and land-use context. Higher overall densities in Nicaragua indicate that land-use history (e.g., frontier age) or other anthropogenic factors may shape the persistence of emergent species at a landscape scale. Beyond D. panamensis, our findings demonstrate that integrating free moderate-resolution optical and SAR datasets enables target crown species mapping at landscape scales and provides a scalable framework for monitoring other ecologically significant or threatened tropical trees.},
 author = {Felipe Saad and Rohit Mukherjee and Geoffrey M. Henebry and Naomi Schwartz and Mario Jimenez and Thomas Lewis and Matthew Fagan},
 doi = {https://doi.org/10.1016/j.rsase.2026.102076},
 issn = {2352-9385},
 journal = {Remote Sensing Applications: Society and Environment},
 keywords = {Large trees, Crown-level mapping, Phenology, Neotropics, Multi-sensor integration},
 pages = {102076},
 title = {Integrating optical and SAR data enables crown-level maps of an emergent tree species, Dipteryx panamensis},
 url = {https://www.sciencedirect.com/science/article/pii/S2352938526002090},
 volume = {42},
 year = {2026}
}
